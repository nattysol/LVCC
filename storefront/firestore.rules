// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: batches
// Document ID: batchId
// Fields:
//   - id: string (required)
//   - orderId: string (required)
//   - recipeName: string (required)
//   - status: string (required, enum: ["pending", "in-progress", "completed", "halted"])
//   - currentStageIndex: int (required)
//   - targetTemp: number
//   - targetHumidity: number
//   - clientName: string
//   - projectName: string
//   - createdAt: timestamp
//
// Collection: batches/{batchId}/stages
// Document ID: stageId
// Fields:
//   - batchId: string (required)
//   - name: string (required)
//   - order: int (required)
//   - status: string (required, enum: ["pending", "active", "completed"])
//   - startTime: timestamp
//   - endTime: timestamp
//   - elapsedSeconds: int
//
// Collection: batches/{batchId}/logs
// Document ID: logId
// Fields:
//   - batchId: string (required)
//   - timestamp: timestamp (required)
//   - type: string (required, enum: ["info", "warning", "error", "success"])
//   - message: string (required)
//   - technician: string
//
// Collection: batches/{batchId}/ingredients
// Document ID: ingredientId
// Fields:
//   - batchId: string (required)
//   - name: string (required)
//   - amount: number (required)
//   - unit: string (required)
//   - origin: string
//   - description: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "kyle@naturalsolutions.llc");
    }

    function isDocOwner(data) {
      return isAuthenticated() && request.auth.uid == data.uid;
    }

    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidBatch(data) {
      return hasRequiredFields(data, ['id', 'quoteId', 'recipeName', 'status', 'currentStageIndex']) &&
             data.id is string && data.id.size() < 100 &&
             data.quoteId is string && data.quoteId.size() < 100 &&
             data.recipeName is string && data.recipeName.size() < 200 &&
             data.status in ["pending", "in-progress", "completed", "halted"] &&
             data.currentStageIndex is number &&
             (!('specifications' in data) || data.specifications is map) &&
             (!('resources' in data) || data.resources is list);
    }

    function isValidStage(data) {
      return hasRequiredFields(data, ['batchId', 'name', 'order', 'status']) &&
             data.batchId is string &&
             data.name is string && data.name.size() < 100 &&
             data.order is number &&
             data.status in ["pending", "active", "completed"] &&
             (!('qualityData' in data) || data.qualityData is map) &&
             (!('startTime' in data) || data.startTime is string) &&
             (!('endTime' in data) || data.endTime is string);
    }

    function isValidLog(data) {
      return hasRequiredFields(data, ['batchId', 'timestamp', 'type', 'message']) &&
             data.batchId is string &&
             data.timestamp is string &&
             data.type in ["info", "warning", "error", "success"] &&
             data.message is string && data.message.size() < 1000;
    }

    function isValidInventoryItem(data) {
      return hasRequiredFields(data, ['id', 'name', 'lotNumber', 'stockLevel', 'unit']) &&
             data.id is string &&
             data.name is string && data.name.size() < 200 &&
             data.lotNumber is string && data.lotNumber.size() < 100 &&
             data.stockLevel is number &&
             data.unit is string && data.unit.size() < 20;
    }

    function isValidIngredient(data) {
      return hasRequiredFields(data, ['batchId', 'name', 'amount', 'unit']) &&
             data.batchId is string &&
             data.name is string && data.name.size() < 200 &&
             data.amount is number &&
             data.unit is string && data.unit.size() < 20 &&
             (!('verified' in data) || data.verified is bool);
    }

    function isValidQuote(data) {
      return hasRequiredFields(data, ['clientName', 'projectName', 'email', 'recipe', 'totalCostEstimate', 'status', 'createdAt']) &&
             data.clientName is string && data.clientName.size() < 200 &&
             data.projectName is string && data.projectName.size() < 200 &&
             data.email is string && data.email.size() < 200 &&
             data.recipe is list &&
             data.totalCostEstimate is number &&
             data.status in ["pending", "approved", "rejected"];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if isAuthenticated() && (isDocOwner(resource.data) || isAdmin());
      allow create: if isAuthenticated() && isValidQuote(request.resource.data) && (request.resource.data.uid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /batches/{batchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBatch(request.resource.data);
      allow update: if isAuthenticated() && (isValidBatch(request.resource.data) || isAdmin());
      allow delete: if isAdmin();

      match /stages/{stageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidStage(request.resource.data);
        allow update: if isAuthenticated() && (isValidStage(request.resource.data) || isAdmin());
        allow delete: if isAdmin();
      }

      match /logs/{logId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidLog(request.resource.data);
        allow update: if isAuthenticated() && (isValidLog(request.resource.data) || isAdmin());
        allow delete: if isAdmin();
      }

      match /ingredients/{ingredientId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidIngredient(request.resource.data);
        allow update: if isAuthenticated() && (isValidIngredient(request.resource.data) || isAdmin());
        allow delete: if isAdmin();
      }
    }
  }
}
