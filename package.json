{
  "name": "lv-chocolate-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
  "dev": "concurrently \"npm run dev:backend\" \"npm run dev:storefront\"",
  "dev:backend": "npm run dev --prefix backend",
  "dev:storefront": "npm run dev --prefix storefront",
  "build": "npm run build --prefix backend",
  "start": "npm run start --prefix backend",
  "db:migrate": "npm run db:migrate --prefix backend",
  "lint": "cd storefront && npm run lint"
},
  "dependencies": {
    "concurrently": "^9.1.0"
  }
}