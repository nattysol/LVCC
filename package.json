{
  "name": "lv-chocolate-backend",
  "version": "0.0.1",
  "main": "medusa-config.js",
  "engines": {
    "node": ">=20.0.0"
  },
"scripts": {
    "build": "medusa build",
    "postbuild": "mkdir -p .medusa/server/public/admin && cp package.json .medusa/server/ && cp -r dist .medusa/server/ && cp dist/medusa-config.js .medusa/server/ && cp -r build/public/admin/* .medusa/server/public/admin/ || true",
    "start": "medusa start",
    "dev": "medusa dev",
    "db:migrate": "medusa db:migrate",
    "predeploy": "medusa db:migrate"
  },
      "dependencies": {
    "@medusajs/admin-sdk": "^2.5.1",
    "@medusajs/cli": "^2.5.1",
    "@medusajs/framework": "^2.5.1",
    "@medusajs/medusa": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}