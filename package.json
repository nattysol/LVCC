{
  "name": "lv-chocolate-backend",
  "version": "0.0.1",
  "main": "medusa-config.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "medusa build",
    "postbuild": "mkdir -p .medusa/server/public/admin && cp package.json medusa-config.js .medusa/server/ && cp -a dist/. .medusa/server/ 2>/dev/null || true && cp -a build/. .medusa/server/public/admin/ 2>/dev/null || true",
    "start": "medusa start",
    "dev": "medusa dev",
    "db:migrate": "medusa db:migrate",
    "predeploy": "medusa db:migrate"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "^2.5.1",
    "@medusajs/cache-redis": "^2.13.3",
    "@medusajs/cli": "^2.5.1",
    "@medusajs/event-bus-redis": "^2.13.3",
    "@medusajs/framework": "^2.13.3",
    "@medusajs/medusa": "^2.5.1",
    "@medusajs/utils": "^2.13.3",
    "@medusajs/workflow-engine-redis": "^2.13.3",
    "@tailwindcss/vite": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
