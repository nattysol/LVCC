{
  "name": "lv-chocolate-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
  "dev": "concurrently \"npm run dev:backend\" \"npm run dev:storefront\"",
  "dev:backend": "npm run dev --prefix backend",
  "dev:storefront": "npm run dev --prefix storefront",
 "build": "cd backend && npm install --legacy-peer-deps && npx medusa build",
  "start": "cd backend && npx medusa start",
  "db:migrate": "cd backend && npx medusa db:migrate",
  "lint": "cd storefront && npm run lint"
},
  "dependencies": {
    "concurrently": "^9.1.0"
  }
}