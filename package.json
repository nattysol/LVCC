{
  "name": "lv-chocolate-backend",
  "version": "0.0.1",
  "main": "medusa-config.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
  "build": "npx medusa build",
  "postbuild": "mkdir -p .medusa/server && cp medusa-config.js .medusa/server/medusa-config.js && cp package.json .medusa/server/package.json || true",
  "start": "cd .medusa/server && npx medusa start",
  "db:migrate": "cd .medusa/server && npx medusa db:migrate",
  "predeploy": "cd .medusa/server && npx medusa db:migrate"
},
  "dependencies": {
    "@medusajs/admin-sdk": "^2.5.1",
    "@medusajs/cli": "^2.5.1",
    "@medusajs/framework": "^2.5.1",
    "@medusajs/medusa": "^2.5.1",
    "@medusajs/icons": "^2.13.1",
    "@medusajs/ui": "^4.1.1",
    "prismjs": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}